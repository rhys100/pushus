{
  "name": "pushus",
  "private": true,
  "version": "1.5.0",
  "type": "module",
  "description": "PushUS â€” bank push-ups with your mates. Privacy-first, self-hostable pushup challenge app.",
  "license": "AGPL-3.0-only",
  "scripts": {
    "dev": "vite",
    "build": "npm run og:generate && npm run pwa:generate && tsc -b && vite build",
    "og:generate": "node --experimental-strip-types scripts/generate-og-assets.ts",
    "pwa:generate": "node --experimental-strip-types scripts/generate-pwa-assets.ts",
    "build:stats": "npm run build && node scripts/build-stats.mjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest",
    "test:rls": "vitest run --config vitest.rls.config.ts",
    "test:billing": "vitest run --config vitest.billing.config.ts",
    "test:integration": "node scripts/run-integration-tests.mjs",
    "test:e2e": "playwright test",
    "prepare": "husky",
    "version:check": "node scripts/check-version.mjs",
    "auth:push-email-template": "node scripts/push-auth-email-template.mjs",
    "version:bump": "node scripts/bump-version.mjs",
    "precommit:check": "npm run version:check && node scripts/check-docs-staged.mjs",
    "licenses:generate": "license-checker --production --out THIRD_PARTY_NOTICES.md"
  },
  "dependencies": {
    "@resvg/resvg-wasm": "2.6.2",
    "@supabase/supabase-js": "2.108.2",
    "@tanstack/react-query": "5.59.16",
    "date-fns": "4.1.0",
    "date-fns-tz": "3.2.0",
    "ios-vibrator-pro-max": "3.0.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.30.4",
    "tailwind-merge": "^2.6.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@playwright/test": "1.61.1",
    "@resvg/resvg-js": "2.6.2",
    "@types/node": "22.15.3",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.7.0",
    "autoprefixer": "10.4.20",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "5.0.0",
    "eslint-plugin-react-refresh": "0.4.14",
    "globals": "15.12.0",
    "husky": "9.1.7",
    "license-checker": "25.0.1",
    "postcss": "8.5.15",
    "tailwindcss": "3.4.14",
    "typescript": "5.6.3",
    "typescript-eslint": "8.62.0",
    "vite": "6.4.3",
    "vitest": "3.2.6"
  }
}

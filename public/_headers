/index.html
  Cache-Control: no-store, must-revalidate

/
  Cache-Control: no-store, must-revalidate

# Security headers apply to EVERY route, including SPA deep links like /login,
# /today and /join/<code>. (Cloudflare `_headers` matches request paths, so a
# rule for `/` alone does NOT cover deep links — it must be `/*`.)
# Cache-Control is intentionally NOT set here so the more specific rules below
# (assets immutable, sw/version no-cache) keep governing caching.
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), vibrate=(self)
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co; img-src 'self' data: blob:; font-src 'self' https://fonts.gstatic.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

/version.json
  Cache-Control: no-cache, must-revalidate

/sw.js
  Cache-Control: no-cache, must-revalidate

/manifest.json
  Cache-Control: no-cache, must-revalidate

/manifest.webmanifest
  Cache-Control: no-cache, must-revalidate

# PWA icons/badges have STABLE filenames but their bytes change when regenerated
# (e.g. the dark-icon fix). They must NOT be immutable, or the CDN pins the old
# copy for up to a year. Short TTL + revalidate lets a new deploy's icons through.
/pwa/*
  Cache-Control: public, max-age=3600, must-revalidate

# Vite fingerprints these filenames (content hash in the name), so immutable is
# safe here — any content change produces a brand-new URL.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# PushUS frontend environment (public vars only — copy to .env and fill in)
# Never commit .env or real keys.

# Core
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_APP_NAME=PushUS
VITE_APP_URL=https://www.pushus.app

# Cloudflare Pages Functions (runtime — not VITE_*)
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_ACCESS_TOKEN=  # personal token for npm run auth:push-email-template only — never commit
# APP_URL=https://www.pushus.app
# APP_NAME=PushUS
VITE_SOURCE_REPO_URL=https://github.com/your-org/pushus
VITE_DEPLOYMENT_NAME=PushUS
VITE_IS_MODIFIED_FORK=false

# Billing (frontend UI only — NOT source of truth for write access; Slice 1B)
VITE_BILLING_ENABLED=false
VITE_GOOGLE_AUTH_ENABLED=false
VITE_BILLING_PROVIDER=stripe
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_MONTHLY_PRICE_LABEL=A$12/month
VITE_YEARLY_PRICE_LABEL=A$99/year
VITE_TRIAL_DAYS=45

# Notifications (Phase 3 — web push)
# Generate with: npx web-push generate-vapid-keys
# Web push (Settings → Push reminders). Public key only — see docs/push-reminders-go-live.md
VITE_VAPID_PUBLIC_KEY=

# Edge function secrets (supabase secrets set — NOT in frontend .env)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com
# CRON_SECRET=
